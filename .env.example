# Chatflow AI - Production Environment Variables
# Copy this file to .env and fill in actual values

# === Server & Domain ===
DOMAIN=194.87.69.220.nip.io

# === Application ===
SECRET_KEY=change-me
BOT_API_KEY=change-me
ENVIRONMENT=production

# === Database ===
DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/chatflow_db
