# Chatflow AI - Environment Variables
# Copy this file to .env.production and fill in actual values.
# All variables are read by Pydantic Settings (case-insensitive).

# === Server & Domain ===
DOMAIN=localhost
ENVIRONMENT=development
DEBUG=True
APP_NAME=ChatFlow AI

# === Auth ===
SECRET_KEY=change-me
BOT_API_KEY=change-me

# === Database ===
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/chatflow_db
DATABASE_SYNC_URL=postgresql+psycopg2://user:pass@localhost:5432/chatflow_db

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Logging ===
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=3
LOG_LEVEL=INFO

# === HTTP Proxy (used by Telegram adapter only) ===
HTTP_PROXY=

# === AI (LLM) ===
AI_API_KEY=change-me
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL_NAME=google/gemma-4-26b-a4b-it

# === STT Provider: "groq" (default) or "riva" ===
STT_PROVIDER=groq
STT_API_KEY=change-me
STT_BASE_URL=https://api.groq.com/openai/v1
STT_MODEL_NAME=whisper-large-v3

# === NVIDIA Riva STT (used when STT_PROVIDER=riva) ===
NVIDIA_API_KEY=change-me
RIVA_SERVER_URL=dns:///grpc.nvcf.nvidia.com:443
RIVA_FUNCTION_ID=b0e8b4a5-217c-40b7-9b96-17d84e666317

# === Sentry ===
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
