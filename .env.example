# Chatflow AI - Production Environment Variables
# Copy this file to .env and fill in actual values

# === Server & Domain ===
DOMAIN=194.87.69.220.nip.io

# === Application ===
SECRET_KEY=change-me
BOT_API_KEY=change-me
ENVIRONMENT=production

# === Database ===
DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/chatflow_db
DATABASE_SYNC_URL=postgresql+psycopg2://user:pass@db:5432/chatflow_db

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === AI (LLM) ===
AI_API_KEY=change-me
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL_NAME=google/gemma-4-26b-a4b-it

# === STT (Speech-to-Text) ===
STT_PROVIDER=groq
STT_API_KEY=change-me
STT_BASE_URL=https://api.groq.com/openai/v1
STT_MODEL_NAME=whisper-large-v3

# === NVIDIA Riva STT (used when STT_PROVIDER=riva) ===
NVIDIA_API_KEY=change-me
RIVA_SERVER_URL=dns:///grpc.nvcf.nvidia.com:443
RIVA_FUNCTION_ID=b0e8b4a5-217c-40b7-9b96-17d84e666317

# === Sentry ===
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
